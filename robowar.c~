#define SIZE 5

struct playergrids {
  unsigned pixelstatus** player1grid;
  unsigned pixelstatus** player2grid;
}

struct pixelstatus {
  char type; // 'C' for civilian, 'A' for army
  unsigned char status; // 0 dead, 1 alive
}


playergrid grid1[2][SIZE+2][SIZE+2];

playergrid grid2[2][SIZE+2][SIZE+2];

int cur_step = 0;

const int LEFT = 1;
const int RIGHT = SIZE;
const int TOP = 1;
const int BOTTOM = SIZE;

void init(float p, float k) {

  int i,j;
  
  for(i=0;i<SIZE;i++) {
    for(j=0;j<SIZE;j++) {
      char status1 = (((float)rand())/RAND_MAX < p);
      float a1 = (float)rand()/RAND_MAX;
      char status2 = (((float)rand())/RAND_MAX < p);
      float a2 = (float)rand()/RAND_MAX;
      grid1[cur_step][i][j].status = status1;
      grid1[cur_step][i][j].type = a1 <= k ? 'C' : 'A';
      grid2[cur_step][i][j].status = status2;
      grid2[cur_step][i][j].type = a2 <= k ? 'C' : 'A';
    }
    
  }
  
}

void copy_sides() {

  int i,j;
  const int HALO_TOP = TOP-1;
  const int HALO_BOTTOM = TOP+1;
  const int HALO_LEFT = LEFT-1;
  const int HALO_RIGHT = RIGHT+1;
  
  for(j=LEFT;j<HALO_RIGHT;j++) {
    grid1[cur_step][i][HALO_TOP]=grid1[cur_step][i][BOTTOM];
    grid1[cur_step][i][HALO_BOTTOM]=grid1[cur_step][i][TOP];
    grid2[cur_step][i][HALO_TOP]=grid2[cur_step][i][BOTTOM];
    grid2[cur_step][i][HALO_BOTTOM]=grid2[cur_step][i][TOP];
  }

  for(i=TOP;i<HALO_BOTTOM;i++) {
    grid1[cur_step][i][HALO_LEFT]=grid1[cur_step][i][RIGHT];
    grid1[cur_step][i][HALO_RIGHT]=grid1[cur_step][i][LEFT];
    grid2[cur_step][i][HALO_LEFT]=grid2[cur_step][i][RIGHT];
    grid2[cur_step][i][HALO_RIGHT]=grid2[cur_step][i][LEFT];
  }

  /* copy corners */

  // first player grid

  grid1[cur_step][HALO_TOP][HALO_LEFT] = grid1[cur_step][BOTTOM][RIGHT];
  grid1[cur_step][HALO_TOP][HALO_RIGHT] = grid1[cur_step][BOTTOM][LEFT];
  grid1[cur_step][HALO_BOTTOM][HALO_LEFT] = grid2[cur_step][TOP][RIGHT];
  grid1[cur_step][HALO_BOTTOM][HALO_RIGHT] = grid2[cur_step][TOP][LEFT];

  // second player grid
  
  grid2[cur_step][HALO_TOP][HALO_LEFT] = grid1[cur_step][BOTTOM][RIGHT];
  grid2[cur_step][HALO_TOP][HALO_RIGHT] = grid1[cur_step][BOTTOM][LEFT];
  grid2[cur_step][HALO_BOTTOM][HALO_LEFT] = grid2[cur_step][TOP][RIGHT];
  grid2[cur_step][HALO_BOTTOM][HALO_RIGHT] = grid2[cur_step][TOP][LEFT];
  
}

